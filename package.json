{
  "name": "concurrency-lab",
  "version": "1.0.0",
  "description": "Simulação de processamento em lote: naive (lotes fixos + sequencial) vs otimizado (pool de concorrência), com MongoDB, geração de Excel e envio de e-mail",
  "scripts": {
    "dev": "ts-node-dev --require tsconfig-paths/register --respawn --transpile-only src/server.ts",
    "build": "tsc -p tsconfig.json && tsc-alias -p tsconfig.json",
    "start": "node dist/server.js",
    "seed": "ts-node-dev --require tsconfig-paths/register --transpile-only src/seed/run-seed.ts"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "exceljs": "^4.4.0",
    "express": "^4.19.2",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "http-status-codes": "^2.3.0",
    "mongoose": "^8.5.0",
    "nodemailer": "^6.9.14",
    "p-limit": "^3.1.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/express-rate-limit": "^5.1.3",
    "@types/node": "^20.14.9",
    "@types/nodemailer": "^6.4.15",
    "ts-node-dev": "^2.0.0",
    "tsc-alias": "^1.8.10",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.5.3"
  }
}
