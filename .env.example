PORT=3000
MONGO_URI=mongodb://localhost:27017/concurrency_lab

# Segurança — obrigatórias (app não inicia sem elas)
# API_KEY: chave secreta enviada no header X-API-KEY em todas as requisições
API_KEY=troque-por-um-segredo-forte
# CORS_ORIGIN: em dev use http://localhost:3000 | em produção use https://seu-dominio.com
CORS_ORIGIN=http://localhost:3000
# Janela do rate limit em milissegundos (ex: 60000 = 1 min) e máximo de requests por IP
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=30

NETWORK_LATENCY_MIN_MS=60
NETWORK_LATENCY_MAX_MS=160

OPTIMIZED_CONCURRENCY_LIMIT=5
NAIVE_BATCH_SIZE=5
NAIVE_BATCH_SLEEP_MS=1000

SEED_COUNT=100

# SMTP — use Mailpit via Docker para dev (veja docker-compose.yml)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM=simulador@concurrency-lab.dev
MAIL_TO=destinatario@exemplo.com
